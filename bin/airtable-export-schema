#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["requests"]
# ///
"""
Airtable Base Schema Exporter

Downloads the complete schema of an Airtable base including:
- Tables (name, ID)
- Fields (name, type, description, options)
- Views (name, type)

Usage:
    airtable-export-schema --token YOUR_TOKEN --base BASE_ID
    AIRTABLE_TOKEN=YOUR_TOKEN AIRTABLE_BASE_ID=BASE_ID airtable-export-schema

Credentials can also be placed in a .env file in the current directory.
"""

import argparse
import json
import os
import requests
from datetime import datetime
from pathlib import Path
from typing import Any


def _load_dotenv(env_path: Path) -> None:
    """Load key=value pairs from a .env file into os.environ (no-op if missing)."""
    if not env_path.exists():
        return
    with open(env_path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, _, value = line.partition("=")
            key = key.strip()
            value = value.strip().strip('"').strip("'")
            os.environ.setdefault(key, value)


_load_dotenv(Path.cwd() / ".env")
_load_dotenv(Path(__file__).parent / ".env")


def get_base_info(token: str, base_id: str) -> str:
    """Fetch the base name for a given base ID."""
    url = "https://api.airtable.com/v0/meta/bases"
    headers = {"Authorization": f"Bearer {token}"}
    response = requests.get(url, headers=headers)
    response.raise_for_status()
    bases = response.json().get("bases", [])
    for base in bases:
        if base.get("id") == base_id:
            return base.get("name", base_id)
    return base_id


def get_base_schema(token: str, base_id: str) -> dict[str, Any]:
    """
    Fetch the complete schema for an Airtable base.

    Args:
        token: Airtable Personal Access Token
        base_id: The base ID (starts with 'app')

    Returns:
        Dictionary containing the full base schema
    """
    url = f"https://api.airtable.com/v0/meta/bases/{base_id}/tables"
    headers = {
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json"
    }

    response = requests.get(url, headers=headers)
    response.raise_for_status()

    return response.json()


def _primary_field_name(table: dict[str, Any]) -> str:
    """
    Resolve a table's primary field name from its primaryFieldId.

    The metadata API reports `primaryFieldId` on every table; we match it against
    the field list. Falls back to the first field if the id is missing or unmatched,
    and to "" if the table has no fields.
    """
    fields = table.get("fields", [])
    primary_id = table.get("primaryFieldId")
    if primary_id:
        for field in fields:
            if field.get("id") == primary_id:
                return field.get("name", "")
    return fields[0].get("name", "") if fields else ""


def _build_summary(schema: dict[str, Any]) -> dict[str, Any]:
    """
    Build a per-table stats summary from the schema (no extra API calls).

    All values are derived from the metadata the schema already carries: field and
    view counts come from the array lengths, and the primary field name is resolved
    from `primaryFieldId`.
    """
    tables = schema.get("tables", [])
    table_summaries = [
        {
            "id": table.get("id", ""),
            "name": table.get("name", ""),
            "primaryFieldName": _primary_field_name(table),
            "fieldCount": len(table.get("fields", [])),
            "viewCount": len(table.get("views", [])),
        }
        for table in tables
    ]
    return {
        "tableCount": len(tables),
        "fieldCount": sum(t["fieldCount"] for t in table_summaries),
        "viewCount": sum(t["viewCount"] for t in table_summaries),
        "tables": table_summaries,
    }


def build_output(schema: dict[str, Any], base_id: str, base_name: str) -> dict[str, Any]:
    """
    Wrap the raw Airtable schema with base identity for the JSON export.

    The Airtable metadata API returns only `{"tables": [...]}`; we prepend a
    `base` object so the exported JSON records which base it came from, and a
    `summary` object with per-table stats (field/view counts, primary field) so the
    counts are readable without re-deriving them. The raw `tables` array is left
    untouched, so downstream tools (diff, standards check) that only read `tables`
    are unaffected.
    """
    return {
        "base": {"id": base_id, "name": base_name},
        "summary": _build_summary(schema),
        **schema,
    }


def _md_cell(text: str) -> str:
    """Make a string safe for a single Markdown table cell (no row/column breaks)."""
    return text.replace("\n", " ").replace("\r", " ").replace("|", "\\|").strip()


def _summarize_field_options(field_type: str, options: dict[str, Any]) -> str:
    """
    Return a short, human-readable summary of a field's `options`.

    Covers the option-bearing Airtable field types. Returns "" for types that
    carry no meaningful config. Never truncates — the full schema is in the JSON
    export, and the Markdown is meant to be complete too.
    """
    if not options:
        return ""

    def _result_type() -> str:
        result = options.get("result") or {}
        rtype = result.get("type")
        return f"result: {rtype}" if rtype else ""

    if field_type in ("number", "percent"):
        precision = options.get("precision")
        return f"precision: {precision}" if precision is not None else ""

    if field_type == "currency":
        parts = []
        if options.get("symbol"):
            parts.append(str(options["symbol"]))
        if options.get("precision") is not None:
            parts.append(f"precision: {options['precision']}")
        return " · ".join(parts)

    if field_type == "date":
        name = (options.get("dateFormat") or {}).get("name")
        return name or ""

    if field_type in ("dateTime", "createdTime", "lastModifiedTime"):
        parts = []
        date_name = (options.get("dateFormat") or {}).get("name")
        time_name = (options.get("timeFormat") or {}).get("name")
        if date_name:
            parts.append(date_name)
        if time_name:
            parts.append(time_name)
        if options.get("timeZone"):
            parts.append(str(options["timeZone"]))
        if field_type != "dateTime":
            # createdTime / lastModifiedTime wrap their format in `result`
            result_fmt = options.get("result") or {}
            for sub in (result_fmt.get("options") or {},):
                dn = (sub.get("dateFormat") or {}).get("name")
                tn = (sub.get("timeFormat") or {}).get("name")
                if dn and dn not in parts:
                    parts.append(dn)
                if tn and tn not in parts:
                    parts.append(tn)
        return " · ".join(parts)

    if field_type == "duration":
        return str(options.get("durationFormat") or "")

    if field_type == "rating":
        parts = []
        if options.get("max") is not None:
            parts.append(f"max {options['max']}")
        if options.get("icon"):
            parts.append(str(options["icon"]))
        return " · ".join(parts)

    if field_type == "checkbox":
        parts = []
        if options.get("icon"):
            parts.append(str(options["icon"]))
        if options.get("color"):
            parts.append(str(options["color"]))
        return " · ".join(parts)

    if field_type in ("singleSelect", "multipleSelects", "externalSyncSource"):
        choices = options.get("choices") or []
        names = [c.get("name", "") for c in choices]
        return f"Choices: {', '.join(names)}" if names else ""

    if field_type == "multipleRecordLinks":
        linked = options.get("linkedTableId", "")
        summary = f"→ `{linked}`" if linked else ""
        flags = []
        if options.get("isReversed"):
            flags.append("reversed")
        if options.get("prefersSingleRecordLink"):
            flags.append("single")
        if flags:
            summary = f"{summary} ({', '.join(flags)})".strip()
        return summary

    if field_type == "multipleAttachments":
        return "(reversed)" if options.get("isReversed") else ""

    if field_type == "count":
        link = options.get("recordLinkFieldId")
        return f"via `{link}`" if link else ""

    if field_type in ("rollup", "lookup", "multipleLookupValues"):
        parts = []
        link = options.get("recordLinkFieldId")
        linked_field = options.get("fieldIdInLinkedTable")
        if link and linked_field:
            parts.append(f"via `{link}` → `{linked_field}`")
        elif link:
            parts.append(f"via `{link}`")
        rt = _result_type()
        if rt:
            parts.append(rt)
        return " · ".join(parts)

    if field_type == "formula":
        return _result_type()

    if field_type == "aiText":
        return "AI generated"

    return ""


def format_schema_as_markdown(schema: dict[str, Any], base_id: str, base_name: str) -> str:
    """
    Convert the schema to a readable markdown format.

    Args:
        schema: The raw schema from Airtable API
        base_id: The base ID for reference
        base_name: The human-readable base name

    Returns:
        Markdown-formatted string
    """
    now = datetime.now()
    timestamp = now.strftime("%Y-%m-%d %H:%M")
    lines = [f"# Airtable Base Schema: {base_name} (`{base_id}`) — {timestamp}\n"]
    lines.append(f"**Base:** {base_name}  ")
    lines.append(f"**App ID:** `{base_id}`  ")
    lines.append(f"**Exported:** {timestamp}  ")

    tables = schema.get("tables", [])
    total_fields = sum(len(t.get("fields", [])) for t in tables)
    total_views = sum(len(t.get("views", [])) for t in tables)
    lines.append(
        f"**Tables:** {len(tables)} · **Fields:** {total_fields} · "
        f"**Views:** {total_views}\n"
    )

    for table in tables:
        table_name = table.get("name", "Unnamed Table")
        table_id = table.get("id", "")

        lines.append(f"\n## Table: {table_name}")
        lines.append(f"**ID:** `{table_id}`")
        lines.append(
            f"**Primary field:** {_md_cell(_primary_field_name(table))} · "
            f"**Fields:** {len(table.get('fields', []))} · "
            f"**Views:** {len(table.get('views', []))}"
        )

        # Description if present
        if table.get("description"):
            lines.append(f"\n**Description:** {table['description']}")

        # Fields
        lines.append("\n### Fields\n")
        lines.append("| # | Field Name | Field ID | Type | Options | Description |")
        lines.append("|---|------------|----------|------|---------|-------------|")

        for i, field in enumerate(table.get("fields", []), 1):
            field_name = field.get("name", "")
            field_id = field.get("id", "")
            field_type = field.get("type", "")
            field_desc = _md_cell(field.get("description") or "")
            options_summary = _md_cell(
                _summarize_field_options(field_type, field.get("options") or {})
            )

            lines.append(
                f"| {i} | {field_name} | `{field_id}` | {field_type} | {options_summary} | {field_desc} |"
            )

        # Views
        views = table.get("views", [])
        if views:
            lines.append("\n### Views\n")
            lines.append("| View Name | Type |")
            lines.append("|-----------|------|")
            for view in views:
                view_name = view.get("name", "")
                view_type = view.get("type", "")
                lines.append(f"| {view_name} | {view_type} |")

    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(
        description="Export Airtable base schema to JSON or Markdown"
    )
    parser.add_argument(
        "--token", "-t",
        default=os.environ.get("AIRTABLE_TOKEN"),
        help="Airtable Personal Access Token (or set AIRTABLE_TOKEN env var)"
    )
    parser.add_argument(
        "--base", "-b",
        default=os.environ.get("AIRTABLE_BASE_ID"),
        help="Base ID (starts with 'app') (or set AIRTABLE_BASE_ID env var)"
    )
    parser.add_argument(
        "--output", "-o",
        default="schema.json",
        help="Output filename (use .json or .md extension)"
    )
    parser.add_argument(
        "--format", "-f",
        choices=["json", "markdown", "both"],
        default="both",
        help="Output format"
    )

    args = parser.parse_args()

    if not args.token:
        parser.error("--token is required (or set AIRTABLE_TOKEN env var)")
    if not args.base:
        parser.error("--base is required (or set AIRTABLE_BASE_ID env var)")

    print(f"Fetching schema for base: {args.base}")
    base_name = get_base_info(args.token, args.base)
    print(f"Base name: {base_name}")
    schema = get_base_schema(args.token, args.base)

    # Count tables and fields
    num_tables = len(schema.get("tables", []))
    num_fields = sum(len(t.get("fields", [])) for t in schema.get("tables", []))
    num_views = sum(len(t.get("views", [])) for t in schema.get("tables", []))
    print(f"Found {num_tables} tables, {num_fields} fields, {num_views} views")

    # Build output filename stem from date, time, base name and app ID.
    # Seconds keep two exports in the same minute apart; a counter is appended
    # if a file with the same stem somehow already exists (e.g. two exports
    # within the same second) so an export never overwrites a previous one.
    now = datetime.now()
    timestamp = now.strftime("%Y-%m-%d_%H-%M-%S")
    safe_base_name = base_name.replace(" ", "_").replace("/", "-")
    base_stem = f"{args.base}_{safe_base_name}_{timestamp}_schema"

    extensions = []
    if args.format in ("json", "both"):
        extensions.append(".json")
    if args.format in ("markdown", "both"):
        extensions.append(".md")

    file_stem = base_stem
    counter = 1
    while any(os.path.exists(f"{file_stem}{ext}") for ext in extensions):
        file_stem = f"{base_stem}_{counter}"
        counter += 1

    if args.format in ("json", "both"):
        json_file = f"{file_stem}.json"
        with open(json_file, "w") as f:
            json.dump(build_output(schema, args.base, base_name), f, indent=2)
        print(f"JSON schema saved to: {json_file}")

    if args.format in ("markdown", "both"):
        md_file = f"{file_stem}.md"
        markdown = format_schema_as_markdown(schema, args.base, base_name)
        with open(md_file, "w") as f:
            f.write(markdown)
        print(f"Markdown schema saved to: {md_file}")


if __name__ == "__main__":
    main()
